{
    "name": "python-mastery-pro",
    "version": "1.1.0",
    "description": "Python Mastery Pro App",
    "scripts": {
        "prepare:offline-assets": "node scripts/prepare_offline_assets.js && tailwindcss -c tailwind.config.cjs -i ./styles/tailwind.css -o ./public/tailwind.generated.css --minify",
        "dev": "npm run prepare:offline-assets && vite",
        "build": "npm run audit:scaffolds && npm run prepare:offline-assets && vite build && cp level1_*_codelogic.py level1_*_requirements*.py level1_*_syntax.py level1_*_fr.py dist/ 2>/dev/null; node scripts/generate_offline_manifest.js && node scripts/audit_offline_build.js",
        "audit:offline": "node scripts/audit_offline_build.js",
        "preview": "vite preview",
        "validate:graders": "node scripts/validate_graders.js",
        "audit:graders": "node scripts/audit_graders.js",
        "harden:graders": "node scripts/harden_graders_by_intent.js",
        "source-intent:graders": "node scripts/apply_source_intent_graders.js",
        "audit:metamorphic": "node scripts/audit_metamorphic_graders.js",
        "audit:script-fallback": "node scripts/audit_script_fallback.js",
        "audit:solutions": "node scripts/audit_solution_sections.js",
        "audit:solution-variations": "node scripts/audit_solution_variations.js",
        "audit:solution-semantics": "node scripts/audit_solution_semantics.js",
        "generate:solution-manifest": "node scripts/generate_solution_section_manifest.js",
        "generate:solution-behavior": "node scripts/generate_solution_behavior_manifest.js",
        "generate:solution-alternatives": "node scripts/generate_semantic_solution_alternatives.js",
        "generate:script-examples": "node scripts/generate_simple_script_examples.js",
        "audit:starters": "node scripts/audit_starter_signatures.js",
        "audit:scaffolds": "node scripts/audit_code_scaffolds.js",
        "audit:concepts": "node scripts/audit_python_concepts.js",
        "eval:general-ai": "node scripts/evaluate_general_ai.js",
        "eval:general-ai-final": "node scripts/evaluate_general_ai_adversarial.js",
        "eval:problem-ai": "node scripts/evaluate_problem_ai.js",
        "test:script-fallback": "node scripts/test_script_fallback.js",
        "check:graders": "npm run validate:graders -- --max-failures=0 && npm run audit:graders -- --max-weak-functions 0 --max-unguarded-single-case-no-arg-functions 0 --max-single-case-scripts 826 --max-unguarded-single-case-scripts 0 --max-hardcode-risk-scripts 0 --max-empty-graders 0 && npm run audit:metamorphic -- --min-covered 558 --max-uncovered-common 0 && npm run audit:script-fallback -- --min-eligible 1438 --max-blocked 1 && npm run audit:solutions -- --max-mislabeled=0 && npm run audit:starters && npm run test:script-fallback"
    },
    "dependencies": {
        "@codemirror/autocomplete": "^6.11.1",
        "@codemirror/lang-python": "^6.1.3",
        "@codemirror/language": "^6.9.2",
        "@codemirror/state": "^6.3.1",
        "@codemirror/theme-one-dark": "^6.1.2",
        "@codemirror/view": "^6.22.0",
        "@google/genai": "*",
        "@lezer/highlight": "^1.2.0",
        "@mlc-ai/web-llm": "^0.2.84",
        "@uiw/react-codemirror": "^4.21.21",
        "lucide-react": "^0.294.0",
        "pyodide": "^0.26.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.37",
        "@types/react-dom": "^18.2.15",
        "@vitejs/plugin-react": "^4.2.0",
        "tailwindcss": "^3.4.17",
        "typescript": "^5.2.2",
        "vite": "^5.0.0"
    }
}
